# Aura Pixel Environment Configuration
# Copy this file to .env and fill in your values

# Site Configuration
VITE_SITE_URL=https://aurapixel.com
VITE_SITE_NAME=Aura Pixel
VITE_SITE_DESCRIPTION=Premium Digital Marketing Agency

# Analytics & Tracking
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_GTM_ID=GTM-XXXXXX
VITE_META_PIXEL_ID=XXXXXXXXXX
VITE_GOOGLE_ADS_ID=AW-XXXXXX

# API Configuration
VITE_API_BASE_URL=https://api.aurapixel.com
VITE_API_KEY=your_api_key_here

# EmailJS Configuration (for contact forms)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Social Media Links
VITE_FACEBOOK_URL=https://facebook.com/aurapixel
VITE_INSTAGRAM_URL=https://instagram.com/aurapixel
VITE_LINKEDIN_URL=https://linkedin.com/company/aurapixel
VITE_TWITTER_URL=https://twitter.com/aurapixel

# Contact Information
VITE_CONTACT_EMAIL=hello@aurapixel.com
VITE_CONTACT_PHONE=+1-234-567-890
VITE_CONTACT_ADDRESS=123 Marketing Street, Digital City, DC 10001

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CHATBOT=false
VITE_ENABLE_BLOG=true
